# Discord webhook URL for notifications. Type: string. Example: "https://discord.com/api/webhooks/.../..."
DISCORD_WEBHOOK_URL = ""

# HardverApro URL to scrape for listings. Type: string. Example: "https://hardverapro.hu/aprok/.../index.html"
HARDVERAPRO_URL = ""

# Optional. State file to store the last known listings. Type: string. Example: ".state.json"
STATE_FILE = ".state.json"

# Optional. Encoding for reading/writing files. Type: BufferEncoding (ENUM). Example: "utf-8".
# BufferEncoding values: "ascii", "utf8", "utf-8", "utf16le", "utf-16le", "ucs2", "ucs-2", "base64", "base64url", "latin1", "binary", "hex"
ENCODING = "utf-8"